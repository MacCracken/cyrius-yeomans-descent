# cyrius-yeomans-descent — fuzz entrypoint (scaffold family).
#
# The real M2 parser fuzz harness lives at `fuzz/parser_fuzz.fcyr` and is
# run by `cyrius fuzz` (which discovers fuzz/*.fcyr). This scaffold-family
# stub is retained only so the tests/ tree keeps its .tcyr/.bcyr/.fcyr
# triple; it is intentionally a no-op that exits clean.

fn main() {
    alloc_init();
    println("fuzz: see fuzz/parser_fuzz.fcyr (run via `cyrius fuzz`)");
    return 0;
}

var r = main();
syscall(60, r);
