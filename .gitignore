# Build output
/build/
/dist/

# Resolved deps (auto-generated by `cyrius deps`) — vendored stdlib stays
lib/*.cyr
!lib/k*.cyr

# Lockfile policy: track when git-deps are present, otherwise omit
# cyrius.lock

# Crash dumps
*.core

