# session.cyr — M1-B per-connection session struct + lifecycle.
#
# One Session per accepted client. Heap-allocated at accept via
# fl_alloc, returned to the freelist at disconnect — per ADR 0003 the
# long-running event loop pays for per-conn-lifetime memory exactly
# once per session.
#
# At M1-B the session holds:
#   - the socket fd
#   - rx + tx byte buffers
#   - a coarse phase enum (banner / cmd) — login flow lands at M1-E
#   - an unused telnet-state pointer slot (M1-C will fill it)
#   - an unused player-id slot (M6 will fill it)
#   - a last-activity timestamp (M1-F idle timeout will consume it)
#
# At M1-B the rx path is a stub echo — every line the client sends is
# echoed back. M1-C swaps that for the RFC 854 IAC parser; M2 adds
# verb-noun dispatch on top.

# === Struct field offsets (all i64 / 8 bytes per CLAUDE.md conventions) ===

enum SS {
    SS_FD         = 0;    # connected socket fd (non-blocking)
    SS_PHASE      = 8;    # current PHASE_*
    SS_LAST_MS    = 16;   # monotonic ms of last byte exchanged
    SS_RX_BUF     = 24;   # ptr to raw socket-read scratch (RX_CAP bytes)
    SS_RX_LEN     = 32;   # raw bytes read, pending Telnet decode
    SS_TX_BUF     = 40;   # ptr to tx queue (TX_CAP bytes)
    SS_TX_LEN     = 48;   # bytes queued (write end)
    SS_TX_OFF     = 56;   # bytes already drained to the socket
    SS_OUT_ARMED  = 64;   # 1 iff the fd is currently registered with EPOLLOUT
    SS_TS         = 72;   # Telnet parser state ptr (M1-C)
    SS_PLAYER     = 80;   # player id (M6; 0 until then)
    SS_LINE_BUF   = 88;   # ptr to decoded-data line accumulator (LINE_CAP)
    SS_LINE_LEN   = 96;   # decoded data bytes in the current partial line
    SS_NAME_BUF   = 104;  # ptr to captured player name (NAME_CAP bytes)
    SS_NAME_LEN   = 112;  # length of the captured name
    SS_NEXT       = 120;  # intrusive active-session list (server.cyr owns it)
    SS_PREV       = 128;  # — used by the tick idle sweep (M1-F)
    SS_QUIT       = 136;  # 1 once the `quit` verb asks for teardown (M2)
    SS_ROOM       = 144;  # current room index (M3); -1 until placed
    # Combat stats (M4). Defaults until classes (M5) / persistence (M6).
    SS_HP         = 152;  # current hit points
    SS_MAXHP      = 160;  # max hit points
    SS_AC         = 168;  # armour class (lower = better defence)
    SS_TARGET     = 176;  # mob instance being fought (0 = not engaged)
    SS_HIT        = 184;  # to-hit bonus
    SS_NDICE      = 192;  # weapon damage: dice count
    SS_DSIZE      = 200;  #                die size
    SS_DMOD       = 208;  #                flat modifier
    SS_INV        = 216;  # head of the player's inventory list (M4-E)
    # Class + attributes + ability state (M5).
    SS_CLASS      = 224;  # class index (-1 until chosen)
    SS_STR        = 232;  # strength    — physical damage
    SS_DEX        = 240;  # dexterity   — accuracy / evasion
    SS_CON        = 248;  # constitution — max HP
    SS_TEC        = 256;  # tech        — ability power
    SS_ENERGY     = 264;  # current ability energy
    SS_MAXENERGY  = 272;
    SS_CD0        = 280;  # ability-slot 0 cooldown (ticks remaining)
    SS_CD1        = 288;  # ability-slot 1 cooldown
    SS_CD2        = 296;  # ability-slot 2 cooldown
    SS_GUARD      = 304;  # AC-buff ticks remaining (brace / bypass)
    SS_STIM       = 312;  # damage/hit-buff ticks remaining (stim)
    SS_STEALTH    = 320;  # 1 while sneaking (backstab primed)
    SS_SIZE       = 328;
}

# The published epoll fd, used by room broadcasts (M3-C) and combat
# flushes (M4) to push bytes to sessions immediately. Single-thread loop,
# so a global is safe. Declared here (ahead of combat.cyr); cmd_serve
# (server.cyr) assigns it at startup. 0 outside a running server — flushes
# then no-op safely (drain to a real fd happens only when armed).
var g_epfd = 0;

# Starting combatant profile (a scavenged sidearm). Replaced by class +
# attribute scaling at M5, restored from save at M6.
enum PlayerStat {
    PC_HP    = 30;
    PC_AC    = 8;
    PC_HIT   = 1;
    PC_NDICE = 1;
    PC_DSIZE = 6;
    PC_DMOD  = 1;
}

enum SessConst {
    RX_CAP   = 4096;      # raw socket-read scratch (decoded each readable)
    TX_CAP   = 4096;      # banner + a few command replies
    LINE_CAP = 4096;      # one full decoded line — M2 parser caps at this
    NAME_CAP = 32;        # name buffer (NAME_MAX + headroom)
    NAME_MAX = 16;        # longest accepted player name
    NAME_MIN = 2;         # shortest accepted player name
}

enum Phase {
    PHASE_NAME  = 0;      # awaiting name entry (first prompt after MOTD)
    PHASE_CLASS = 2;      # awaiting class selection (M5-A)
    PHASE_CMD   = 1;      # in the world, accepting commands
}

# === session_new — alloc + zero-init a Session for an accepted fd. ===
fn session_new(fd, now_ms): i64 {
    var s = fl_alloc(SS_SIZE);
    var rxb = fl_alloc(RX_CAP);
    var txb = fl_alloc(TX_CAP);
    var lnb = fl_alloc(LINE_CAP);
    var nmb = fl_alloc(NAME_CAP);
    memset(s, 0, SS_SIZE);
    store64(s + SS_FD, fd);
    store64(s + SS_PHASE, PHASE_NAME);
    store64(s + SS_LAST_MS, now_ms);
    store64(s + SS_RX_BUF, rxb);
    store64(s + SS_TX_BUF, txb);
    store64(s + SS_LINE_BUF, lnb);
    store64(s + SS_NAME_BUF, nmb);
    store64(s + SS_TS, telnet_state_new());
    store64(s + SS_ROOM, 0 - 1);   # unplaced until login (M3)
    # Default combatant profile (M4).
    store64(s + SS_HP, PC_HP);
    store64(s + SS_MAXHP, PC_HP);
    store64(s + SS_AC, PC_AC);
    store64(s + SS_TARGET, 0);
    store64(s + SS_HIT, PC_HIT);
    store64(s + SS_NDICE, PC_NDICE);
    store64(s + SS_DSIZE, PC_DSIZE);
    store64(s + SS_DMOD, PC_DMOD);
    store64(s + SS_CLASS, 0 - 1);   # no class until selected (M5)
    return s;
}

# === session_free — close fd, return buffers to the freelist. ===
fn session_free(s): i64 {
    sock_close(load64(s + SS_FD));
    telnet_state_free(load64(s + SS_TS));
    fl_free(load64(s + SS_RX_BUF));
    fl_free(load64(s + SS_TX_BUF));
    fl_free(load64(s + SS_LINE_BUF));
    fl_free(load64(s + SS_NAME_BUF));
    fl_free(s);
    return 0;
}

# === session_appendtx — copy `len` bytes into the tx queue. ===
#
# Truncates on overflow (returns the number of bytes actually queued).
# At M1-B the queue is one banner + short replies — overflow is a bug,
# not an expected condition, but we cap rather than corrupt memory.
fn session_appendtx(s, buf, len): i64 {
    var pos = load64(s + SS_TX_LEN);
    var cap = TX_CAP;
    var room = cap - pos;
    var n = len;
    if (n > room) { n = room; }
    if (n <= 0) { return 0; }
    memcpy(load64(s + SS_TX_BUF) + pos, buf, n);
    store64(s + SS_TX_LEN, pos + n);
    return n;
}

# Convenience: append a NUL-terminated cstring.
fn session_appendtx_cstr(s, cstr): i64 {
    return session_appendtx(s, cstr, strlen(cstr));
}

# Append a signed integer in decimal. Used by the M1-H status verb.
fn session_appendtx_num(s, n): i64 {
    if (n == 0) {
        var z[1];
        store8(&z, 48);
        session_appendtx(s, &z, 1);
        return 0;
    }
    if (n < 0) {
        var m[1];
        store8(&m, 45);          # '-'
        session_appendtx(s, &m, 1);
        n = 0 - n;
    }
    var tmp[24];
    var len = 0;
    while (n > 0) {
        store8(&tmp + len, 48 + (n % 10));
        n = n / 10;
        len = len + 1;
    }
    var out[24];
    var i = 0;
    while (i < len) {
        store8(&out + i, load8(&tmp + len - 1 - i));
        i = i + 1;
    }
    session_appendtx(s, &out, len);
    return 0;
}

# === session_telnet_announce — queue the opening option salvo. ===
#
# Runs telnet_announce on the session's parser and copies the resulting
# IAC bytes into the tx queue. Called once at accept, ahead of the
# banner, so a conformant client negotiates ECHO / SGA before any
# application bytes arrive.
fn session_telnet_announce(s): i64 {
    var ts = load64(s + SS_TS);
    telnet_announce(ts);
    var txl = telnet_tx_len(ts);
    if (txl > 0) {
        session_appendtx(s, telnet_tx_buf(ts), txl);
        telnet_tx_consume(ts);
    }
    return 0;
}

# === session_drain — try to write any queued tx bytes to the socket. ===
#
# Returns:
#   2 = drained completely (queue is now empty)
#   1 = partial (would-block; caller should arm EPOLLOUT)
#   0 = nothing to drain
#   negative = socket error (caller should disconnect)
fn session_drain(s): i64 {
    var tx_len = load64(s + SS_TX_LEN);
    var tx_off = load64(s + SS_TX_OFF);
    if (tx_off >= tx_len) { return 0; }
    var fd = load64(s + SS_FD);
    var done = 0;
    var rc = 1;
    while (done == 0) {
        if (tx_off >= tx_len) { done = 1; rc = 2; continue; }
        var n = sys_write(fd, load64(s + SS_TX_BUF) + tx_off, tx_len - tx_off);
        if (n < 0) {
            # EAGAIN / EWOULDBLOCK (-11) means the kernel buffer is full —
            # we keep the unsent bytes and let the caller arm EPOLLOUT.
            # Anything else is a real error.
            if (n == 0 - 11) { done = 1; rc = 1; continue; }
            done = 1;
            rc = n;
            continue;
        }
        if (n == 0) { done = 1; rc = 1; continue; }
        tx_off = tx_off + n;
    }
    if (rc == 2) {
        # Empty queue — reset offsets so the next append starts at 0.
        store64(s + SS_TX_LEN, 0);
        store64(s + SS_TX_OFF, 0);
    } else {
        store64(s + SS_TX_OFF, tx_off);
    }
    return rc;
}

# === Login flow (M1-E scaffold). ===
#
# MOTD → name prompt → MOTD-2 → command prompt. The name is captured
# but NOT authenticated — real identity / auth lands at M6 (ADR 0004).
# Reserved handles and ill-formed names are refused with a re-prompt.

fn ascii_lower(c): i64 {
    if (c >= 65) { if (c <= 90) { return c + 32; } }
    return c;
}

# Case-insensitive compare of buf[0..len] against NUL-terminated lit.
fn name_eq_ci(buf, len, lit): i64 {
    var i = 0;
    while (i < len) {
        var lc = load8(lit + i) & 0xFF;
        if (lc == 0) { return 0; }                  # lit shorter than buf
        if (ascii_lower(load8(buf + i) & 0xFF) != ascii_lower(lc)) { return 0; }
        i = i + 1;
    }
    if ((load8(lit + i) & 0xFF) != 0) { return 0; } # lit longer than buf
    return 1;
}

fn is_alpha(c): i64 {
    if (c >= 65)  { if (c <= 90)  { return 1; } }
    if (c >= 97)  { if (c <= 122) { return 1; } }
    return 0;
}
fn is_alnum(c): i64 {
    if (is_alpha(c) == 1) { return 1; }
    if (c >= 48) { if (c <= 57) { return 1; } }
    return 0;
}

# Validate a candidate player name. Returns 1 if acceptable. Rules:
#   - length in [NAME_MIN, NAME_MAX]
#   - first char a letter (rules out leading '_' and digits)
#   - every char alphanumeric
#   - not a reserved handle (system / admin)
fn login_name_ok(buf, len): i64 {
    if (len < NAME_MIN) { return 0; }
    if (len > NAME_MAX) { return 0; }
    if (is_alpha(load8(buf) & 0xFF) == 0) { return 0; }
    var i = 0;
    while (i < len) {
        if (is_alnum(load8(buf + i) & 0xFF) == 0) { return 0; }
        i = i + 1;
    }
    if (name_eq_ci(buf, len, "system") == 1) { return 0; }
    if (name_eq_ci(buf, len, "admin")  == 1) { return 0; }
    return 1;
}

fn session_send_motd(s): i64 {
    session_appendtx_cstr(s, "\r\n");
    session_appendtx_cstr(s, "  ============================================\r\n");
    session_appendtx_cstr(s, "        Y E O M A N ' S   D E S C E N T\r\n");
    session_appendtx_cstr(s, "     a MUD of the techno-feudal Under-Grid\r\n");
    session_appendtx_cstr(s, "  ============================================\r\n");
    session_appendtx_cstr(s, "\r\n");
    return 0;
}
fn session_send_name_prompt(s): i64 {
    session_appendtx_cstr(s, "By what name are you known? ");
    return 0;
}
fn session_send_cmd_prompt(s): i64 {
    session_appendtx_cstr(s, "> ");
    return 0;
}

# Send MOTD + the first name prompt; the session starts in PHASE_NAME.
# Called once at accept (replaces the M1-B placeholder banner).
fn session_begin_login(s): i64 {
    store64(s + SS_PHASE, PHASE_NAME);
    session_send_motd(s);
    session_send_name_prompt(s);
    return 0;
}

# Handle a line entered at the name prompt.
fn login_on_name(s, buf, len): i64 {
    if (login_name_ok(buf, len) == 0) {
        session_appendtx_cstr(s, "That name won't do — 2-16 letters/digits, no reserved handles.\r\n");
        session_send_name_prompt(s);
        return 0;
    }
    # Capture the name (unauthenticated) and advance to class selection.
    memcpy(load64(s + SS_NAME_BUF), buf, len);
    store64(s + SS_NAME_LEN, len);
    store64(s + SS_PHASE, PHASE_CLASS);
    session_appendtx_cstr(s, "\r\nWelcome, ");
    session_appendtx(s, buf, len);
    session_appendtx_cstr(s, ". The Under-Grid stirs.\r\n");
    class_send_prompt(s);   # forward ref → classes.cyr (M5-A)
    return 0;
}

# === M2 command dispatch ===
#
# One shared parser for every session — parsing a line is synchronous and
# never spans calls, so the single-thread loop needs only one instance
# (lazily allocated on first command). The world the verbs act on lands
# at M3; until then the handlers acknowledge the *parse* (verb / objects /
# preposition recognized) rather than faking world state, which keeps the
# wiring honest and demonstrable.
var g_parser = 0;

# Append token `i` of the parser (its lowercased form) to the tx queue.
fn session_appendtx_tok(s, pa, i): i64 {
    if (i < 0) { return 0; }
    session_appendtx(s, tok_ptr(pa, i), tok_len(pa, i));
    return 0;
}

# Index where the command line's remainder begins: past leading
# whitespace, past the first word, past the whitespace after it. Returns
# `len` when there is no remainder (a bare verb). Used by social verbs to
# echo the original (case-preserving) message text.
fn cmd_rest_start(buf, len): i64 {
    var i = 0;
    while (i < len) {
        var c = load8(buf + i) & 0xFF;
        if (c != 32) { if (c != 9) { break; } }
        i = i + 1;
    }
    while (i < len) {
        var c = load8(buf + i) & 0xFF;
        if (c == 32) { break; }
        if (c == 9)  { break; }
        i = i + 1;
    }
    while (i < len) {
        var c = load8(buf + i) & 0xFF;
        if (c != 32) { if (c != 9) { break; } }
        i = i + 1;
    }
    return i;
}

# say <message> — the speaker sees `You say, "X"`; everyone else in the
# room sees `<name> says, "X"`.
fn cmd_say(s, buf, len): i64 {
    var rs = cmd_rest_start(buf, len);
    if (rs >= len) { session_appendtx_cstr(s, "Say what?\r\n"); return 0; }
    session_appendtx_cstr(s, "You say, \"");
    session_appendtx(s, buf + rs, len - rs);
    session_appendtx_cstr(s, "\"\r\n");
    room_say_broadcast(load64(s + SS_ROOM), s, s, " says, \"", buf + rs, len - rs, "\"\r\n");
    return 0;
}

# emote <action> — everyone in the room (the actor included) sees
# `<name> <action>`.
fn cmd_emote(s, buf, len): i64 {
    var rs = cmd_rest_start(buf, len);
    if (rs >= len) { session_appendtx_cstr(s, "Emote what?\r\n"); return 0; }
    session_appendtx(s, load64(s + SS_NAME_BUF), load64(s + SS_NAME_LEN));
    session_appendtx_cstr(s, " ");
    session_appendtx(s, buf + rs, len - rs);
    session_appendtx_cstr(s, "\r\n");
    room_say_broadcast(load64(s + SS_ROOM), s, s, " ", buf + rs, len - rs, "\r\n");
    return 0;
}

# tell <player> <message> — a directed message to any connected player,
# regardless of room.
fn cmd_tell(s, pa, buf, len): i64 {
    if (load64(g_parser + PA_COUNT) < 2) {
        session_appendtx_cstr(s, "Tell whom what?\r\n");
        return 0;
    }
    # Message begins after the second word (verb, then target name).
    var rs1 = cmd_rest_start(buf, len);
    var rs2 = rs1 + cmd_rest_start(buf + rs1, len - rs1);
    if (rs2 >= len) { session_appendtx_cstr(s, "Tell them what?\r\n"); return 0; }

    var target = find_player_global(tok_ptr(pa, 1), tok_len(pa, 1));
    if (target == 0) {
        session_appendtx_cstr(s, "No one by that name is connected.\r\n");
        return 0;
    }
    if (target == s) {
        session_appendtx_cstr(s, "Talking to yourself already?\r\n");
        return 0;
    }
    # Recipient sees the incoming tell (flushed now — they may be idle).
    session_appendtx_cstr(target, "\r\n");
    session_appendtx(target, load64(s + SS_NAME_BUF), load64(s + SS_NAME_LEN));
    session_appendtx_cstr(target, " tells you, \"");
    session_appendtx(target, buf + rs2, len - rs2);
    session_appendtx_cstr(target, "\"\r\n");
    deliver_to(target);
    # Sender's echo.
    session_appendtx_cstr(s, "You tell ");
    session_appendtx(s, load64(target + SS_NAME_BUF), load64(target + SS_NAME_LEN));
    session_appendtx_cstr(s, ", \"");
    session_appendtx(s, buf + rs2, len - rs2);
    session_appendtx_cstr(s, "\"\r\n");
    return 0;
}

# An object verb (get / drop / kill / ...): reflect the parsed structure.
# With no world yet (M3), every noun resolves to nothing — but the parse
# is shown so the verb-noun machinery is visible end to end.
fn cmd_object(s, pa, verb): i64 {
    if (parsed_has_dobj(pa) == 0) {
        session_appendtx_cstr(s, verb_name(verb));
        session_appendtx_cstr(s, " what?\r\n");
        return 0;
    }
    session_appendtx_cstr(s, "You move to ");
    session_appendtx_cstr(s, verb_name(verb));
    session_appendtx_cstr(s, " the ");
    session_appendtx_tok(s, pa, parsed_dobj(pa));
    if (parsed_has_iobj(pa) == 1) {
        session_appendtx_cstr(s, " ");
        session_appendtx_cstr(s, prep_name(parsed_prep(pa)));
        session_appendtx_cstr(s, " the ");
        session_appendtx_tok(s, pa, parsed_iobj(pa));
    }
    session_appendtx_cstr(s, ", but the Under-Grid is empty — items arrive at M3.\r\n");
    return 0;
}

# Brief in-game help: the verb classes the parser understands.
fn cmd_help_text(s): i64 {
    session_appendtx_cstr(s, "-- commands --\r\n");
    session_appendtx_cstr(s, "move    : n s e w u d (north ...)\r\n");
    session_appendtx_cstr(s, "look    : look(l) examine exits inventory(i) who\r\n");
    session_appendtx_cstr(s, "items   : get drop put give wear remove wield\r\n");
    session_appendtx_cstr(s, "fight   : kill flee\r\n");
    session_appendtx_cstr(s, "social  : say tell emote\r\n");
    session_appendtx_cstr(s, "session : quit save help   admin: @stats\r\n");
    class_append_abilities(s);   # forward ref → classes.cyr (M5)
    return 0;
}

# === ANSI SGR (M3-D) ===
#
# We emit raw SGR escapes inline into the wire stream rather than pull the
# external `darshana` styling lib: that lib is a client-side terminal
# renderer, the wrong layer for a server queuing ~4 escape codes into a tx
# buffer. Keeping these here preserves the zero-external-deps stance and
# the "Own the Stack" principle. `\x1b` is a one-byte ESC in Cyrius
# strings, so the codes embed directly in cstr literals.
fn ansi_reset(): i64 { return "\x1b[0m"; }      # clear all attributes
fn ansi_title(): i64 { return "\x1b[1;33m"; }   # bold yellow — room title
fn ansi_exits(): i64 { return "\x1b[36m"; }     # cyan — exits line
fn ansi_actor(): i64 { return "\x1b[1;32m"; }   # bold green — players
fn ansi_mob(): i64   { return "\x1b[31m"; }     # red — hostiles

# List the mobs present in room `room` (one per line, red). The mob.cyr
# instance list hangs off the Room struct's RM_MOB_HEAD.
fn session_append_mobs(s, room): i64 {
    var m = room_mob_head(room_at(room));
    while (m != 0) {
        session_appendtx_cstr(s, ansi_mob());
        session_appendtx(s, mi_name_ptr(m), mi_name_len(m));
        session_appendtx_cstr(s, " is here");
        # Show wounds (a fresh, unhurt mob reads cleaner without the tag).
        if (mi_hp(m) < mt_hp(mi_tpl(m))) {
            session_appendtx_cstr(s, " (");
            session_appendtx_cstr(s, mob_condition(m));
            session_appendtx_cstr(s, ")");
        }
        session_appendtx_cstr(s, ".");
        session_appendtx_cstr(s, ansi_reset());
        session_appendtx_cstr(s, "\r\n");
        m = mi_next(m);
    }
    return 0;
}

# Append the exits line for room `r` (cyan label, dir words). Shared by
# session_show_room and the `exits` verb.
fn session_append_exits(s, r): i64 {
    session_appendtx_cstr(s, ansi_exits());
    session_appendtx_cstr(s, "Exits:");
    var any = 0;
    var d = 0;
    while (d < NDIR) {
        if (room_exit(r, d) >= 0) {
            session_appendtx_cstr(s, " ");
            session_appendtx_cstr(s, dir_name(d));
            any = 1;
        }
        d = d + 1;
    }
    if (any == 0) { session_appendtx_cstr(s, " none"); }
    session_appendtx_cstr(s, ansi_reset());
    session_appendtx_cstr(s, "\r\n");
    return 0;
}

# === M3 room display + movement ===
#
# session_show_room renders the room at SS_ROOM into the session tx queue:
# bold-yellow title, default-weight prose, cyan exits, green present
# players. room_append_present (in server.cyr, which owns the session
# list) adds the other players here.
fn session_show_room(s): i64 {
    var room = load64(s + SS_ROOM);
    if (room < 0) { return 0; }
    if (world_room_count() == 0) { return 0; }
    var r = room_at(room);

    session_appendtx_cstr(s, "\r\n");
    session_appendtx_cstr(s, ansi_title());
    session_appendtx(s, room_title_ptr(r), room_title_len(r));
    session_appendtx_cstr(s, ansi_reset());
    session_appendtx_cstr(s, "\r\n");
    session_appendtx(s, room_prose_ptr(r), room_prose_len(r));
    session_appendtx_cstr(s, "\r\n");
    session_append_exits(s, r);
    session_append_objs(s, room);   # forward ref → item.cyr
    session_append_mobs(s, room);
    room_append_present(s, room);   # forward ref → server.cyr
    return 0;
}

# Place a freshly-logged-in session into the world (start room) and show
# it. No-op when no zone is loaded (the M2-era placeholder verbs still
# answer). Announces the arrival to anyone already in the start room.
fn session_enter_world(s): i64 {
    if (world_room_count() == 0) { return 0; }
    var start = world_start_room();
    store64(s + SS_ROOM, start);
    room_broadcast(start, s, s, " flickers into being here.", "", "\r\n");
    session_show_room(s);
    return 0;
}

# Move a session one step in `dir`. Validates the exit, broadcasts the
# departure / arrival to onlookers, and auto-looks the mover.
fn cmd_move(s, dir): i64 {
    if (world_room_count() == 0) {
        session_appendtx_cstr(s, "The way ");
        session_appendtx_cstr(s, dir_name(dir));
        session_appendtx_cstr(s, " is sealed — no zone is loaded.\r\n");
        return 0;
    }
    var cur = load64(s + SS_ROOM);
    if (cur < 0) { cur = world_start_room(); store64(s + SS_ROOM, cur); }

    var dest = room_exit(room_at(cur), dir);
    if (dest < 0) {
        session_appendtx_cstr(s, "You can't go that way.\r\n");
        return 0;
    }

    # Departure notice to the room being left, arrival to the room entered.
    room_broadcast(cur, s, s, " heads ", dir_name(dir), ".\r\n");
    store64(s + SS_ROOM, dest);
    room_broadcast(dest, s, s, " arrives.", "", "\r\n");
    session_show_room(s);
    return 0;
}

# Case-insensitive prefix match: is np[0..nl) (already lowercased) a
# prefix of name_buf[0..name_len)? Used to match a typed noun against a
# present player's name.
fn name_prefix_match(name_buf, name_len, np, nl): i64 {
    if (nl <= 0)        { return 0; }
    if (nl > name_len)  { return 0; }
    var i = 0;
    while (i < nl) {
        if (ascii_lower(load8(name_buf + i) & 0xFF) != (load8(np + i) & 0xFF)) { return 0; }
        i = i + 1;
    }
    return 1;
}

# examine <noun> — inspect self, or a player present in the room. Objects
# and mobs (which carry the `keywords` scope the M2 resolver matches) land
# at M4/M5; until then the live scope is the room's players.
fn cmd_examine(s, pa): i64 {
    if (parsed_has_dobj(pa) == 0) {
        session_appendtx_cstr(s, "Examine what?\r\n");
        return 0;
    }
    var di = parsed_dobj(pa);
    if (tok_eq(pa, di, "me") == 1) { return examine_self(s); }
    if (tok_eq(pa, di, "self") == 1) { return examine_self(s); }

    var other = room_find_player(s, load64(s + SS_ROOM), tok_ptr(pa, di), tok_len(pa, di));
    if (other != 0) {
        session_appendtx_cstr(s, ansi_actor());
        session_appendtx(s, load64(other + SS_NAME_BUF), load64(other + SS_NAME_LEN));
        session_appendtx_cstr(s, ansi_reset());
        session_appendtx_cstr(s, " stands here, taking in the Under-Grid.\r\n");
        return 0;
    }
    # A mob in the room?
    var m = mob_in_room_by_kw(load64(s + SS_ROOM), tok_ptr(pa, di), tok_len(pa, di));
    if (m != 0) {
        var tpl = mi_tpl(m);
        session_appendtx_cstr(s, ansi_mob());
        session_appendtx(s, mi_name_ptr(m), mi_name_len(m));
        session_appendtx_cstr(s, ansi_reset());
        session_appendtx_cstr(s, "\r\n");
        if (mt_desc_len(tpl) > 0) {
            session_appendtx(s, mt_desc_ptr(tpl), mt_desc_len(tpl));
            session_appendtx_cstr(s, "\r\n");
        }
        session_appendtx_cstr(s, "It looks ");
        session_appendtx_cstr(s, mob_condition(m));
        session_appendtx_cstr(s, ".\r\n");
        return 0;
    }
    session_appendtx_cstr(s, "You see no ");
    session_appendtx_tok(s, pa, di);
    session_appendtx_cstr(s, " here.\r\n");
    return 0;
}

fn examine_self(s): i64 {
    session_appendtx_cstr(s, "You are ");
    session_appendtx_cstr(s, ansi_actor());
    session_appendtx(s, load64(s + SS_NAME_BUF), load64(s + SS_NAME_LEN));
    session_appendtx_cstr(s, ansi_reset());
    var cls = load64(s + SS_CLASS);
    if (cls >= 0) {
        session_appendtx_cstr(s, ", ");
        session_appendtx(s, class_name_ptr(cls), class_name_len(cls));   # forward ref → classes.cyr
    }
    session_appendtx_cstr(s, ".\r\n");
    # Vitals + attributes.
    session_appendtx_cstr(s, "  HP ");
    session_appendtx_num(s, load64(s + SS_HP));
    session_appendtx_cstr(s, "/");
    session_appendtx_num(s, load64(s + SS_MAXHP));
    session_appendtx_cstr(s, "   Energy ");
    session_appendtx_num(s, load64(s + SS_ENERGY));
    session_appendtx_cstr(s, "/");
    session_appendtx_num(s, load64(s + SS_MAXENERGY));
    session_appendtx_cstr(s, "\r\n");
    session_appendtx_cstr(s, "  STR ");
    session_appendtx_num(s, load64(s + SS_STR));
    session_appendtx_cstr(s, "  DEX ");
    session_appendtx_num(s, load64(s + SS_DEX));
    session_appendtx_cstr(s, "  CON ");
    session_appendtx_num(s, load64(s + SS_CON));
    session_appendtx_cstr(s, "  TEC ");
    session_appendtx_num(s, load64(s + SS_TEC));
    session_appendtx_cstr(s, "   AC ");
    session_appendtx_num(s, load64(s + SS_AC));
    session_appendtx_cstr(s, "\r\n");
    return 0;
}

# Dispatch one parsed command. `buf`/`len` is the original line (for
# case-preserving social echo). Sets SS_QUIT on `quit`.
fn cmd_dispatch(s, pa, buf, len): i64 {
    var verb = parsed_verb(pa);

    if (verb == VERB_UNKNOWN) {
        if (parser_count(pa) == 0) { return 0; }   # blank line — just re-prompt
        session_appendtx_cstr(s, "I don't understand \"");
        session_appendtx_tok(s, pa, 0);
        session_appendtx_cstr(s, "\".  Try \"help\".\r\n");
        return 0;
    }

    if (verb_is_movement(verb) == 1) {
        return cmd_move(s, verb_to_dir(verb));
    }

    if (verb == VERB_QUIT) {
        session_appendtx_cstr(s, "The Under-Grid releases you. Farewell.\r\n");
        store64(s + SS_QUIT, 1);
        return 0;
    }
    if (verb == VERB_HELP) { return cmd_help_text(s); }
    if (verb == VERB_SAVE) {
        session_appendtx_cstr(s, "Nothing to save yet — persistence lands at M6.\r\n");
        return 0;
    }

    if (verb == VERB_LOOK) {
        if (world_room_count() == 0) { session_appendtx_cstr(s, "Darkness. No zone is loaded.\r\n"); return 0; }
        session_show_room(s);
        return 0;
    }
    if (verb == VERB_EXITS) {
        if (world_room_count() == 0) { session_appendtx_cstr(s, "No exits — no zone is loaded.\r\n"); return 0; }
        session_append_exits(s, room_at(load64(s + SS_ROOM)));
        return 0;
    }
    if (verb == VERB_EXAMINE)   { return cmd_examine(s, pa); }
    if (verb == VERB_INVENTORY) { return cmd_inventory(s); }
    if (verb == VERB_WHO)       { return cmd_who(s); }

    if (verb == VERB_GET)  { return cmd_get(s, pa); }
    if (verb == VERB_DROP) { return cmd_drop(s, pa); }

    if (verb == VERB_SAY)   { return cmd_say(s, buf, len); }
    if (verb == VERB_TELL)  { return cmd_tell(s, pa, buf, len); }
    if (verb == VERB_EMOTE) { return cmd_emote(s, buf, len); }

    if (verb == VERB_KILL)  { return cmd_kill(s, pa); }
    if (verb == VERB_FLEE)  { return cmd_flee(s); }
    if (verb_is_ability(verb) == 1) { return cmd_ability(s, pa, verb); }

    # Remaining item verbs all take a direct object.
    return cmd_object(s, pa, verb);
}

# Handle a line entered at the command prompt (PHASE_CMD). `@stats` stays
# an admin verb outside the world table (M1-H); everything else routes
# through the M2 verb-noun parser. render_stats lives in server.cyr,
# where the observability counters do (resolved as a forward reference).
fn cmd_on_line(s, buf, len): i64 {
    if (name_eq_ci(buf, len, "@stats") == 1) {
        render_stats(s);
        session_send_cmd_prompt(s);
        return 0;
    }
    if (g_parser == 0) { g_parser = parser_new(); }
    parser_parse(g_parser, buf, len);
    cmd_dispatch(s, g_parser, buf, len);
    if (load64(s + SS_QUIT) == 0) { session_send_cmd_prompt(s); }
    return 0;
}

# === session_on_line — dispatch one complete decoded line by phase. ===
#
# `buf` / `len` is the line with its CR / LF terminator already stripped.
fn session_on_line(s, buf, len): i64 {
    if (load64(s + SS_PHASE) == PHASE_NAME) {
        return login_on_name(s, buf, len);
    }
    if (load64(s + SS_PHASE) == PHASE_CLASS) {
        return login_on_class(s, buf, len);   # forward ref → classes.cyr
    }
    return cmd_on_line(s, buf, len);
}

# === session_push_line_byte — append one decoded data byte to the line. ===
#
# CR is the canonical line terminator. CR LF collapses to one line: the
# CR dispatches, then the paired LF arrives with the line already empty
# and is dropped. A lone LF (Unix-style `nc` clients) terminates a
# non-empty line too. Over-long lines (no terminator within LINE_CAP)
# reset with a wire warning — M2 will reject these as a parse error.
fn session_push_line_byte(s, b): i64 {
    var ln = load64(s + SS_LINE_BUF);
    var len = load64(s + SS_LINE_LEN);
    if (b == 13) {
        session_on_line(s, ln, len);
        store64(s + SS_LINE_LEN, 0);
        return 0;
    }
    if (b == 10) {
        # len == 0 here is the LF half of a CR LF pair — absorb it.
        if (len == 0) { return 0; }
        session_on_line(s, ln, len);
        store64(s + SS_LINE_LEN, 0);
        return 0;
    }
    if (len >= LINE_CAP) {
        store64(s + SS_LINE_LEN, 0);
        session_appendtx_cstr(s, "(line too long — buffer reset)\r\n");
        return 0;
    }
    store8(ln + len, b);
    store64(s + SS_LINE_LEN, len + 1);
    return 0;
}

# === session_consume_rx — Telnet-decode pending rx bytes. ===
#
# Feeds every raw byte read this round through the per-session Telnet
# parser. IAC sequences are consumed by the state machine; any reply it
# queues (option negotiation) is copied into our tx queue so it goes out
# in on-wire order ahead of application data. Decoded data bytes flow
# into the line accumulator, which dispatches complete lines to
# session_on_line. The raw rx buffer is scratch — fully consumed here,
# so SS_RX_LEN resets to 0 on return.
fn session_consume_rx(s): i64 {
    var rx = load64(s + SS_RX_BUF);
    var len = load64(s + SS_RX_LEN);
    var ts = load64(s + SS_TS);
    var i = 0;
    while (i < len) {
        var ev = telnet_feed(ts, load8(rx + i));
        # Drain any negotiation reply into the tx queue before the data
        # byte, preserving RFC 854 on-wire ordering.
        var txl = telnet_tx_len(ts);
        if (txl > 0) {
            session_appendtx(s, telnet_tx_buf(ts), txl);
            telnet_tx_consume(ts);
        }
        if (ev == EV_DATA) {
            session_push_line_byte(s, telnet_data_byte(ts) & 0xFF);
        }
        # EV_SB / EV_NONE: nothing for the application at M1-C/M1-D.
        i = i + 1;
    }
    store64(s + SS_RX_LEN, 0);
    return 0;
}

# === session_is_idle — has this session been silent past the limit? ===
#
# Pure predicate over SS_LAST_MS (updated on every inbound byte). The
# tick sweep (server.cyr) uses it to reap slowloris-style quiet clients.
# Returns 1 if (now - last) >= timeout_ms.
fn session_is_idle(s, now_ms, timeout_ms): i64 {
    if (now_ms - load64(s + SS_LAST_MS) >= timeout_ms) { return 1; }
    return 0;
}

# === session_on_readable — pull bytes from the socket into rx. ===
#
# Returns 1 if the session should stay alive, 0 if it should be torn
# down (clean EOF or socket error).
fn session_on_readable(s, now_ms): i64 {
    var rx = load64(s + SS_RX_BUF);
    var len = load64(s + SS_RX_LEN);
    var fd = load64(s + SS_FD);
    var done = 0;
    var alive = 1;
    while (done == 0) {
        var room = RX_CAP - len;
        if (room <= 0) { done = 1; continue; }
        var n = sys_read(fd, rx + len, room);
        if (n < 0) {
            # EAGAIN → drained for now. Anything else → real error.
            if (n != 0 - 11) { alive = 0; }
            done = 1;
            continue;
        }
        if (n == 0) {
            # Clean EOF.
            alive = 0;
            done = 1;
            continue;
        }
        len = len + n;
    }
    store64(s + SS_RX_LEN, len);
    if (len > 0) { store64(s + SS_LAST_MS, now_ms); }
    session_consume_rx(s);
    return alive;
}
